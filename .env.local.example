# Base URL for metadata, sitemap, and OG images
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: enable live orderbook depth data (Polymarket + Kalshi)
# ENABLE_ORDERBOOK_DEPTH=1

# Optional: enable smart money / top holders data (Polymarket only)
# ENABLE_SMART_MONEY=1

# Optional: custom path for persistent operator-index snapshots/outcomes store
# INDEX_STORE_PATH=./.predpulse/index-store.json

# Optional: set to "false" to disable hero section and compact pulse cards
# NEXT_PUBLIC_HERO_ENABLED=true

# Optional: enable low-compute directional-core3 Pulse model
# INDEX_CORE3_ENABLED=true

# Optional: disable 25-row UI paging over 50-row API windows (enabled by default)
# MARKETS_DOUBLE_PAGE_ENABLED=false
# NEXT_PUBLIC_MARKETS_DOUBLE_PAGE_ENABLED=false

# Optional websocket controls (defaults: Polymarket on, Kalshi/Manifold off)
# NEXT_PUBLIC_ENABLE_POLY_WS=true
# NEXT_PUBLIC_ENABLE_KALSHI_WS=false
# NEXT_PUBLIC_ENABLE_MANIFOLD_WS=false
# NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=3
